{
  "name": "nadsafe",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "clients/web",
    "clients/extension"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=clients/web",
    "build:web": "npm run build --workspace=clients/web",
    "build:ext": "npm run build --workspace=clients/extension",
    "build:all": "npm run build:web && npm run build:ext",
    "test:crypto": "cargo test -p nadsafe-crypto-core",
    "check": "cargo check && npm run build:all"
  }
}
